{
    "version": "2.0.0",
    "problemMatcher": "$gcc",
    "tasks": [
                {
            "label": "🧼 clean",
            "type": "shell",
            "command": "make clean",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "⚒️ build example (debug)",
            "type": "shell",
            "command": "make example",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "⚒️ build example (release)",
            "type": "shell",
            "command": "make example BUILD=release",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "▶️ run example (auto-login)",
            "type": "shell",
            "command": "./example/build/example -l root -p 1234",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "⌨️ create python env",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "python3 -m venv .venv && source .venv/bin/activate && pip install --upgrade pip && pip install -r requirements.txt"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "📝 format project",
            "type": "shell",
            "command": "./utils/code-format.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "🧪 test: all",
            "type": "shell",
            "command": ".venv/bin/pytest tests -v",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
